#!/usr/bin/env sh

# Auto-sync local branch with remote before push to reduce non-fast-forward failures.
remote_name="$1"
remote_url="$2"

if [ -z "$remote_name" ]; then
  remote_name="origin"
fi

current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ -z "$current_branch" ] || [ "$current_branch" = "HEAD" ]; then
  exit 0
fi

upstream_ref="refs/remotes/$remote_name/$current_branch"

# Keep remote refs up to date.
git fetch "$remote_name" "$current_branch" >/dev/null 2>&1 || exit 1

local_sha=$(git rev-parse HEAD 2>/dev/null)
remote_sha=$(git rev-parse "$upstream_ref" 2>/dev/null)
base_sha=$(git merge-base HEAD "$upstream_ref" 2>/dev/null)

# If no upstream branch exists yet, allow normal push.
if [ -z "$remote_sha" ]; then
  exit 0
fi

# Local is up to date or ahead only -> push can continue.
if [ "$local_sha" = "$remote_sha" ] || [ "$remote_sha" = "$base_sha" ]; then
  exit 0
fi

# Local is behind: auto-rebase to integrate remote changes first.
if [ "$local_sha" = "$base_sha" ]; then
  echo "[pre-push] Remote branch is ahead. Running pull --rebase before push..."
  git pull --rebase --autostash "$remote_name" "$current_branch" || {
    echo "[pre-push] Auto-rebase failed. Resolve conflicts, then push again."
    exit 1
  }
  exit 0
fi

# Diverged history: attempt rebase, otherwise stop.
echo "[pre-push] Branch has diverged. Attempting pull --rebase..."
git pull --rebase --autostash "$remote_name" "$current_branch" || {
  echo "[pre-push] Divergence requires manual conflict resolution."
  exit 1
}

exit 0
