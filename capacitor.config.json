{
  "appId": "com.rpsls.mobile",
  "appName": "RPSLS Tournament",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#0f172a",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#0f172a",
      "overlaysWebView": false
    }
  }
}
